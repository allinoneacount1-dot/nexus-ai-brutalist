---
// Capabilities - brutalist
---

<section id="capabilities" class="border-b-2 border-[var(--color-border)] bg-[var(--color-bg-primary)]">
  <div class="wrap py-4">
    <div class="flex items-center justify-center gap-4">
      <span class="text-[var(--color-fg-secondary)]" aria-hidden="true">[</span>
      <h2 class="macro-type text-base md:text-lg">CAPABILITIES</h2>
      <span class="text-[var(--color-fg-secondary)]" aria-hidden="true">]</span>
      <span class="micro-type text-[10px]">MODULE INDEX</span>
    </div>
  </div>
  <div class="border-t-2 border-b-2 border-[var(--color-border)]">
    <div class="brutalist-grid grid-cols-1 md:grid-cols-2">
      <div class="p-6 md:p-10 text-center border-b md:border-b-0 md:border-r border-[var(--color-border)]">
        <div class="macro-type text-5xl md:text-6xl text-[var(--color-accent)] mb-6">01</div>
        <h3 class="macro-type text-xl md:text-2xl mb-4">PREDICTIVE ANALYTICS</h3>
        <p class="micro-type text-[10px] leading-relaxed mb-6 max-w-xs mx-auto">ADVANCED MACHINE LEARNING MODELS TRAINED ON 42.8B TOKENS OF MARKET DATA, SOCIAL SENTIMENT, AND ON-CHAIN METRICS.</p>
        <div class="micro-type text-[10px] text-[var(--color-terminal-green)]">+ ACTIVE</div>
        <div class="sep my-4"></div>
        <div class="micro-type text-[10px] text-[var(--color-fg-primary)]">F1: 0.967 // AUC-ROC: 0.984</div>
      </div>
      <div class="p-6 md:p-10 text-center border-b md:border-b-0 border-[var(--color-border)]">
        <div class="macro-type text-5xl md:text-6xl text-[var(--color-accent)] mb-6">02</div>
        <h3 class="macro-type text-xl md:text-2xl mb-4">RISK ASSESSMENT</h3>
        <p class="micro-type text-[10px] leading-relaxed mb-6 max-w-xs mx-auto">MULTI-FACTOR RISK SCORING ENGINE ANALYZING PORTFOLIO EXPOSURE, CORRELATION MATRICES, AND VOLATILITY REGIMES.</p>
        <div class="micro-type text-[10px] text-[var(--color-terminal-green)]">+ ACTIVE</div>
        <div class="sep my-4"></div>
        <div class="micro-type text-[10px] text-[var(--color-fg-primary)]">SHARPE: 2.34 // SORTINO: 3.12</div>
      </div>
      <div class="p-6 md:p-10 text-center border-b md:border-b-0 md:border-r border-[var(--color-border)]">
        <div class="macro-type text-5xl md:text-6xl text-[var(--color-accent)] mb-6">03</div>
        <h3 class="macro-type text-xl md:text-2xl mb-4">SENTIMENT ANALYSIS</h3>
        <p class="micro-type text-[10px] leading-relaxed mb-6 max-w-xs mx-auto">NATURAL LANGUAGE PROCESSING ACROSS 50+ DATA SOURCES INCLUDING SOCIAL MEDIA, NEWS FEEDS, AND DEVELOPER ACTIVITY.</p>
        <div class="micro-type text-[10px] text-[var(--color-terminal-green)]">+ ACTIVE</div>
        <div class="sep my-4"></div>
        <div class="micro-type text-[10px] text-[var(--color-fg-primary)]">SOURCES: 53 // CONFIDENCE: 0.91</div>
      </div>
      <div class="p-6 md:p-10 text-center">
        <div class="macro-type text-5xl md:text-6xl text-[var(--color-accent)] mb-6">04</div>
        <h3 class="macro-type text-xl md:text-2xl mb-4">PORTFOLIO OPTIMIZATION</h3>
        <p class="micro-type text-[10px] leading-relaxed mb-6 max-w-xs mx-auto">MEAN-VARIANCE OPTIMIZATION WITH CONSTRAINTS. DYNAMIC REBALANCING BASED ON REGIME DETECTION.</p>
        <div class="micro-type text-[10px] text-[var(--color-terminal-green)]">+ ACTIVE</div>
        <div class="sep my-4"></div>
        <div class="micro-type text-[10px] text-[var(--color-fg-primary)]">ALPHA: +3.2% // DRAWDOWN: -4.1%</div>
      </div>
    </div>
  </div>
</section>
