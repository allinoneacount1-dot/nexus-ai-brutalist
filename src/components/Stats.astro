---
// Stats - brutalist
---

<section id="stats" class="border-b-2 border-[var(--color-border)] bg-[var(--color-bg-primary)]">
  <div class="wrap py-4">
    <div class="flex items-center justify-center gap-4">
      <span class="text-[var(--color-fg-secondary)]" aria-hidden="true">[</span>
      <h2 class="macro-type text-base md:text-lg">ANALYTICS</h2>
      <span class="text-[var(--color-fg-secondary)]" aria-hidden="true">]</span>
      <span class="micro-type text-[10px]">AGGREGATE METRICS</span>
    </div>
  </div>
  <div class="border-t-2 border-b-2 border-[var(--color-border)]">
    <div class="brutalist-grid grid-cols-2 md:grid-cols-4">
      <div class="p-6 md:p-8 text-center border-r border-[var(--color-border)]">
        <div class="macro-type text-4xl md:text-5xl mb-2">$4.2<span class="text-xl">B</span></div>
        <div class="micro-type text-[10px]">ASSETS UNDER ANALYSIS</div>
      </div>
      <div class="p-6 md:p-8 text-center border-r border-[var(--color-border)]">
        <div class="macro-type text-4xl md:text-5xl mb-2">2.8<span class="text-xl">M</span></div>
        <div class="micro-type text-[10px]">MODELS TRAINED</div>
      </div>
      <div class="p-6 md:p-8 text-center border-r border-[var(--color-border)]">
        <div class="macro-type text-4xl md:text-5xl mb-2">312</div>
        <div class="micro-type text-[10px]">ACTIVE DEPLOYMENTS</div>
      </div>
      <div class="p-6 md:p-8 text-center">
        <div class="macro-type text-4xl md:text-5xl mb-2">18<span class="text-xl">ms</span></div>
        <div class="micro-type text-[10px]">EDGE RESPONSE TIME</div>
      </div>
    </div>
  </div>
  <div class="py-3 overflow-hidden">
    <div class="ticker-track" aria-label="Live cryptocurrency prices">
      <span class="micro-type text-[10px] whitespace-nowrap px-4">BTC: $67,842.31 <span class="text-[var(--color-terminal-green)]">+2.4%</span></span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">ETH: $3,891.47 <span class="text-[var(--color-terminal-green)]">+1.8%</span></span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">SOL: $187.23 <span class="text-[var(--color-accent)]">-0.7%</span></span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">AVAX: $42.18 <span class="text-[var(--color-terminal-green)]">+3.1%</span></span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">MARKET CAP: $2.84T</span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">24H VOL: $89.2B</span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">BTC.D: 54.2%</span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">BTC: $67,842.31 <span class="text-[var(--color-terminal-green)]">+2.4%</span></span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">ETH: $3,891.47 <span class="text-[var(--color-terminal-green)]">+1.8%</span></span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">SOL: $187.23 <span class="text-[var(--color-accent)]">-0.7%</span></span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">AVAX: $42.18 <span class="text-[var(--color-terminal-green)]">+3.1%</span></span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">MARKET CAP: $2.84T</span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">24H VOL: $89.2B</span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
      <span class="micro-type text-[10px] whitespace-nowrap px-4">BTC.D: 54.2%</span>
      <span class="text-[var(--color-border)] px-2" aria-hidden="true">|</span>
    </div>
  </div>
</section>
