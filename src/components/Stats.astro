---
// Stats section - large numbers with monospace
---

<section id="stats" class="border-b border-[var(--color-border)]">
  <div class="max-w-[1400px] mx-auto">
    <!-- Section header -->
    <div class="border-b border-[var(--color-border)] px-4 md:px-8 py-4">
      <div class="flex items-center justify-between">
        <h2 class="macro-type text-lg md:text-xl">
          <span class="ascii-frame">Analytics</span>
        </h2>
        <span class="micro-type text-[10px]">AGGREGATE METRICS</span>
      </div>
    </div>

    <!-- Stats grid -->
    <div class="brutalist-grid grid-cols-2 md:grid-cols-4">
      <div class="p-6 md:p-8 text-center">
        <div class="macro-type text-4xl md:text-6xl mb-2">$4.2<span class="text-xl md:text-2xl">B</span></div>
        <div class="data-readout">Assets Under Analysis</div>
      </div>
      <div class="p-6 md:p-8 text-center border-l border-[var(--color-border)]">
        <div class="macro-type text-4xl md:text-6xl mb-2">2.8<span class="text-xl md:text-2xl">M</span></div>
        <div class="data-readout">Models Trained</div>
      </div>
      <div class="p-6 md:p-8 text-center border-l border-[var(--color-border)]">
        <div class="macro-type text-4xl md:text-6xl mb-2">142<span class="text-xl md:text-2xl">ms</span></div>
        <div class="data-readout">Avg Inference Time</div>
      </div>
      <div class="p-6 md:p-8 text-center border-l border-[var(--color-border)]">
        <div class="macro-type text-4xl md:text-6xl mb-2">97.3<span class="text-xl md:text-2xl">%</span></div>
        <div class="data-readout">Prediction Accuracy</div>
      </div>
    </div>

    <!-- Bottom ticker -->
    <div class="border-t border-[var(--color-border)] px-4 md:px-8 py-3 overflow-hidden">
      <div class="flex items-center gap-8 animate-pulse">
        <span class="data-readout whitespace-nowrap">BTC: $67,842.31</span>
        <span class="text-[var(--color-border)]">|</span>
        <span class="data-readout whitespace-nowrap">ETH: $3,891.47</span>
        <span class="text-[var(--color-border)]">|</span>
        <span class="data-readout whitespace-nowrap">SOL: $187.23</span>
        <span class="text-[var(--color-border)]">|</span>
        <span class="data-readout whitespace-nowrap">Market Cap: $2.84T</span>
        <span class="text-[var(--color-border)]">|</span>
        <span class="data-readout whitespace-nowrap whitespace-nowrap">24H VOL: $89.2B</span>
      </div>
    </div>
  </div>
</section>
