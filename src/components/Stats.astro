---
// Stats - bigger numbers, more space
---

<section id="stats" class="border-b border-[var(--color-border)]">
  <div class="max-w-[1400px] mx-auto">
    <!-- Section header -->
    <div class="border-b border-[var(--color-border)] px-6 md:px-12 py-5">
      <div class="flex items-center justify-between">
        <h2 class="macro-type text-lg md:text-xl">
          <span class="text-[var(--color-fg-secondary)]">[ </span>Analytics<span class="text-[var(--color-fg-secondary)]"> ]</span>
        </h2>
        <span class="micro-type text-[10px]">AGGREGATE METRICS</span>
      </div>
    </div>

    <!-- Stats grid -->
    <div class="brutalist-grid grid-cols-2 md:grid-cols-4">
      <div class="p-8 md:p-12 text-center">
        <div class="macro-type text-5xl md:text-7xl mb-3">$4.2<span class="text-2xl md:text-3xl">B</span></div>
        <div class="data-readout text-base">Assets Under Analysis</div>
      </div>
      <div class="p-8 md:p-12 text-center">
        <div class="macro-type text-5xl md:text-7xl mb-3">2.8<span class="text-2xl md:text-3xl">M</span></div>
        <div class="data-readout text-base">Models Trained</div>
      </div>
      <div class="p-8 md:p-12 text-center">
        <div class="macro-type text-5xl md:text-7xl mb-3">312</div>
        <div class="data-readout text-base">Active Deployments</div>
      </div>
      <div class="p-8 md:p-12 text-center">
        <div class="macro-type text-5xl md:text-7xl mb-3">18<span class="text-2xl md:text-3xl">ms</span></div>
        <div class="data-readout text-base">Edge Response Time</div>
      </div>
    </div>

    <!-- Scrolling ticker -->
    <div class="border-t border-[var(--color-border)] py-4 overflow-hidden">
      <div class="ticker-track" aria-label="Live cryptocurrency prices">
        <span class="data-readout whitespace-nowrap px-6">BTC: $67,842.31 <span class="text-[var(--color-terminal-green)]">+2.4%</span></span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">ETH: $3,891.47 <span class="text-[var(--color-terminal-green)]">+1.8%</span></span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">SOL: $187.23 <span class="text-[var(--color-accent)]">-0.7%</span></span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">AVAX: $42.18 <span class="text-[var(--color-terminal-green)]">+3.1%</span></span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">Market Cap: $2.84T</span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">24H VOL: $89.2B</span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">BTC.D: 54.2%</span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <!-- Duplicate for seamless loop -->
        <span class="data-readout whitespace-nowrap px-6">BTC: $67,842.31 <span class="text-[var(--color-terminal-green)]">+2.4%</span></span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">ETH: $3,891.47 <span class="text-[var(--color-terminal-green)]">+1.8%</span></span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">SOL: $187.23 <span class="text-[var(--color-accent)]">-0.7%</span></span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">AVAX: $42.18 <span class="text-[var(--color-terminal-green)]">+3.1%</span></span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">Market Cap: $2.84T</span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">24H VOL: $89.2B</span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
        <span class="data-readout whitespace-nowrap px-6">BTC.D: 54.2%</span>
        <span class="text-[var(--color-border)] px-3" aria-hidden="true">|</span>
      </div>
    </div>
  </div>
</section>
