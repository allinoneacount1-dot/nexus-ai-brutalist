---
// CTA - brutalist
---

<section id="access" class="border-b-2 border-[var(--color-border)] bg-[var(--color-bg-primary)]">
  <div class="wrap py-20 md:py-32">
    <div class="text-center mb-12">
      <div class="micro-type text-[10px] mb-6 text-[var(--color-accent)]">[ ACCESS REQUEST ]</div>
      <h2 style="font-family: var(--font-display); text-transform: uppercase; letter-spacing: -0.04em; line-height: 0.9; font-weight: 900; font-size: clamp(3rem, 8vw, 8rem);">REQUEST<br/><span style="color: var(--color-accent);">ACCESS</span></h2>
      <div style="text-align: center; margin: 2rem auto; max-width: 672px;">
        <p style="font-family: var(--font-mono); color: var(--color-fg-secondary); text-transform: uppercase; letter-spacing: 0.12em; line-height: 1.8; font-size: 0.75rem;">
          [ LIMITED AVAILABILITY. SYSTEM ACCESS GRANTED TO QUALIFIED ENTITIES WITH DEMONSTRATED INSTITUTIONAL REQUIREMENTS. ]
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#" class="btn-brutalist-accent btn-brutalist text-[10px]">[ REQUEST ACCESS → ]</a>
        <a href="#" class="btn-brutalist text-[10px]">[ DOCUMENTATION ]</a>
      </div>
    </div>
    <div class="brutalist-grid grid-cols-2 md:grid-cols-4">
      <div class="p-4 md:p-6 text-center border-r border-[var(--color-border)]">
        <div class="macro-type text-2xl md:text-3xl mb-2">$1M</div>
        <div class="micro-type text-[10px]">MINIMUM AUM</div>
      </div>
      <div class="p-4 md:p-6 text-center border-r border-[var(--color-border)]">
        <div class="macro-type text-2xl md:text-3xl mb-2">FUND</div>
        <div class="micro-type text-[10px]">ENTITY TYPE</div>
      </div>
      <div class="p-4 md:p-6 text-center border-r border-[var(--color-border)]">
        <div class="macro-type text-2xl md:text-3xl mb-2">SEC</div>
        <div class="micro-type text-[10px]">REGULATED</div>
      </div>
      <div class="p-4 md:p-6 text-center">
        <div class="macro-type text-2xl md:text-3xl mb-2">5-10d</div>
        <div class="micro-type text-[10px]">REVIEW PERIOD</div>
      </div>
    </div>
  </div>
</section>
