---
// CTA - full width, centered content
---

<section id="access" class="border-b border-[var(--color-border)] w-full">
  <div class="w-full px-6 md:px-12 lg:px-20 py-24 md:py-40">
    <div class="max-w-[1600px] mx-auto">
      <div class="max-w-2xl mx-auto text-center mb-16">
        <div class="micro-type mb-8 text-[var(--color-accent)]">Access Request</div>
        <h2 class="macro-type type-display mb-8">
          REQUEST<br/>
          <span class="text-[var(--color-accent)]">ACCESS</span>
        </h2>
        <p class="type-sub font-mono text-[var(--color-fg-secondary)] uppercase tracking-wider leading-relaxed mb-12 mx-auto">
          Limited availability. System access granted to qualified entities 
          with demonstrated institutional requirements.
        </p>
        <div class="flex flex-wrap justify-center gap-6">
          <a href="#" class="btn-brutalist-accent btn-brutalist">[ Request Access → ]</a>
          <a href="#" class="btn-brutalist">[ Documentation ]</a>
        </div>
      </div>

      <!-- Requirements grid -->
      <div class="brutalist-grid grid-cols-2 md:grid-cols-4">
        <div class="p-6 md:p-8 text-center">
          <div class="macro-type text-3xl md:text-4xl mb-3">$1M</div>
          <div class="data-readout text-base">Minimum AUM</div>
        </div>
        <div class="p-6 md:p-8 text-center">
          <div class="macro-type text-3xl md:text-4xl mb-3">FUND</div>
          <div class="data-readout text-base">Entity Type</div>
        </div>
        <div class="p-6 md:p-8 text-center">
          <div class="macro-type text-3xl md:text-4xl mb-3">SEC</div>
          <div class="data-readout text-base">Regulated</div>
        </div>
        <div class="p-6 md:p-8 text-center">
          <div class="macro-type text-3xl md:text-4xl mb-3">5-10d</div>
          <div class="data-readout text-base">Review Period</div>
        </div>
      </div>
    </div>
  </div>
</section>
