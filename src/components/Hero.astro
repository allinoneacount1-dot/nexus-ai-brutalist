---
// Hero - full viewport, SVG geometric mark, tactile CTAs
---

<section class="border-b border-[var(--color-border)] hero-full relative overflow-hidden">
  <div class="warning-stripe"></div>

  <!-- Geometric SVG mark -->
  <svg class="geo-mark" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <rect x="20" y="20" width="360" height="360" stroke="currentColor" stroke-width="1" opacity="0.4"/>
    <rect x="60" y="60" width="280" height="280" stroke="currentColor" stroke-width="1" opacity="0.3"/>
    <rect x="100" y="100" width="200" height="200" stroke="currentColor" stroke-width="1" opacity="0.2"/>
    <line x1="0" y1="200" x2="400" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.2"/>
    <line x1="200" y1="0" x2="200" y2="400" stroke="currentColor" stroke-width="0.5" opacity="0.2"/>
    <circle cx="200" cy="200" r="80" stroke="currentColor" stroke-width="0.5" opacity="0.15"/>
    <text x="200" y="205" text-anchor="middle" font-family="monospace" font-size="11" fill="currentColor" opacity="0.5">NEXUS-7</text>
    <line x1="180" y1="220" x2="220" y2="220" stroke="currentColor" stroke-width="1" opacity="0.3"/>
  </svg>

  <div class="max-w-[1400px] mx-auto px-4 md:px-8 py-16 md:py-0 relative z-10">
    <!-- Top data row -->
    <div class="flex flex-wrap items-center justify-between gap-4 mb-12 md:mb-24">
      <div class="data-readout">
        SYS.STATUS: <span class="text-[var(--color-terminal-green)]">OPERATIONAL</span>
      </div>
      <div class="data-readout">
        REV 2.6 // UNIT / D-01 // CLASSIFICATION: PUBLIC
      </div>
    </div>

    <!-- Main hero content -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-8 lg:gap-16 items-center">
      <!-- Left: Main headline -->
      <div>
        <h1 class="macro-type type-hero mb-6 md:mb-10">
          NEXUS<br/>
          <span class="text-[var(--color-accent)]">AI</span>
        </h1>
        <div class="accent-line w-32 md:w-56 mb-6 md:mb-8"></div>
        <p class="type-sub font-mono text-[var(--color-fg-secondary)] max-w-[50ch] uppercase tracking-wider leading-relaxed mb-8">
          Tactical intelligence extraction system for autonomous decision-making architectures.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#access" class="btn-brutalist-accent btn-brutalist">[ Request Access → ]</a>
          <a href="#telemetry" class="btn-brutalist">[ View Telemetry ]</a>
        </div>
      </div>

      <!-- Right: Data panel -->
      <div class="border border-[var(--color-border)] p-4 md:p-6 w-full lg:w-80">
        <div class="micro-type mb-4 text-[var(--color-accent)]">System Parameters</div>
        <div class="space-y-3">
          <div class="flex justify-between border-b border-[var(--color-border)] pb-2">
            <span class="data-readout">Model Version</span>
            <span class="data-readout text-[var(--color-fg-primary)]">NEXUS-7.2.1</span>
          </div>
          <div class="flex justify-between border-b border-[var(--color-border)] pb-2">
            <span class="data-readout">Training Data</span>
            <span class="data-readout text-[var(--color-fg-primary)]">42.8B TOKENS</span>
          </div>
          <div class="flex justify-between border-b border-[var(--color-border)] pb-2">
            <span class="data-readout">Inference Speed</span>
            <span class="data-readout text-[var(--color-terminal-green)]">142ms</span>
          </div>
          <div class="flex justify-between border-b border-[var(--color-border)] pb-2">
            <span class="data-readout">Accuracy Index</span>
            <span class="data-readout text-[var(--color-fg-primary)]">97.3%</span>
          </div>
          <div class="flex justify-between">
            <span class="data-readout">Uptime</span>
            <span class="data-readout text-[var(--color-terminal-green)]">99.97%</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom data row -->
    <div class="mt-12 md:mt-24 pt-6 md:pt-8 border-t border-[var(--color-border)]">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="data-readout">
          [ COORDINATES: 40.7128N / 74.0060W ]
        </div>
        <div class="data-readout">
          SESSION: {new Date().toISOString().split('T')[0].replace(/-/g, '.')} // NODE: US-EAST-1
        </div>
      </div>
    </div>
  </div>
</section>
