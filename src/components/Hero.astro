---
// Hero section - massive typography, tactical data readouts
---

<section class="border-b border-[var(--color-border)]">
  <!-- Warning stripe -->
  <div class="warning-stripe"></div>

  <div class="max-w-[1400px] mx-auto px-4 md:px-8 py-12 md:py-24">
    <!-- Top data row -->
    <div class="flex flex-wrap items-center justify-between gap-4 mb-8 md:mb-16">
      <div class="data-readout">
        SYS.STATUS: <span class="text-[var(--color-terminal-green)]">OPERATIONAL</span>
      </div>
      <div class="data-readout">
        REV 2.6 // UNIT / D-01 // CLASSIFICATION: PUBLIC
      </div>
    </div>

    <!-- Main hero content -->
    <div class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-8 lg:gap-16">
      <!-- Left: Main headline -->
      <div>
        <h1 class="macro-type type-hero mb-4 md:mb-8">
          NEXUS<br/>
          <span class="text-[var(--color-accent)]">AI</span>
        </h1>
        <div class="accent-line w-32 md:w-48 mb-6 md:mb-8"></div>
        <p class="type-sub font-mono text-[var(--color-fg-secondary)] max-w-[50ch] uppercase tracking-wider leading-relaxed">
          Tactical intelligence extraction system for autonomous decision-making architectures.
        </p>
      </div>

      <!-- Right: Data panel -->
      <div class="border border-[var(--color-border)] p-4 md:p-6">
        <div class="micro-type mb-4 text-[var(--color-accent)]">System Parameters</div>
        <div class="space-y-3 data-readout">
          <div class="flex justify-between border-b border-[var(--color-border)] pb-2">
            <span>Model Version</span>
            <span class="text-[var(--color-fg-primary)]">NEXUS-7.2.1</span>
          </div>
          <div class="flex justify-between border-b border-[var(--color-border)] pb-2">
            <span>Training Data</span>
            <span class="text-[var(--color-fg-primary)]">42.8B TOKENS</span>
          </div>
          <div class="flex justify-between border-b border-[var(--color-border)] pb-2">
            <span>Inference Speed</span>
            <span class="text-[var(--color-terminal-green)]">142ms</span>
          </div>
          <div class="flex justify-between border-b border-[var(--color-border)] pb-2">
            <span>Accuracy Index</span>
            <span class="text-[var(--color-fg-primary)]">97.3%</span>
          </div>
          <div class="flex justify-between">
            <span>Uptime</span>
            <span class="text-[var(--color-terminal-green)]">99.97%</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom data row -->
    <div class="mt-8 md:mt-16 pt-6 md:pt-8 border-t border-[var(--color-border)]">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="data-readout">
          [ COORDINATES: 40.7128N / 74.0060W ]
        </div>
        <div class="data-readout">
          SESSION: {new Date().toISOString().split('T')[0].replace(/-/g, '.')} // NODE: US-EAST-1
        </div>
      </div>
    </div>
  </div>
</section>
