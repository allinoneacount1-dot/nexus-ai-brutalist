---
// Telemetry - unique data, no duplication with Stats
---

<section id="telemetry" class="border-b border-[var(--color-border)]">
  <div class="max-w-[1400px] mx-auto">
    <!-- Section header -->
    <div class="border-b border-[var(--color-border)] px-4 md:px-8 py-4">
      <div class="flex items-center justify-between">
        <h2 class="macro-type text-lg md:text-xl">
          <span class="text-[var(--color-fg-secondary)]">[ </span>Telemetry<span class="text-[var(--color-fg-secondary)]"> ]</span>
        </h2>
        <span class="micro-type text-[10px]">LIVE FEED</span>
      </div>
    </div>

    <!-- Telemetry grid - different layout: asymmetric 2-col -->
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr]">
      <!-- Left: Main metric -->
      <div class="p-6 md:p-10 border-b md:border-b-0 md:border-r border-[var(--color-border)]">
        <div class="micro-type mb-4 text-[var(--color-accent)]">Neural Processing</div>
        <div class="macro-type text-6xl md:text-8xl mb-3">847</div>
        <div class="data-readout mb-6">Queries processed / 24h</div>
        <div class="sep mb-6"></div>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <div class="data-readout text-[var(--color-fg-primary)]">142ms</div>
            <div class="data-readout text-[10px]">AVG LATENCY</div>
          </div>
          <div>
            <div class="data-readout text-[var(--color-fg-primary)]">289ms</div>
            <div class="data-readout text-[10px]">P99 LATENCY</div>
          </div>
          <div>
            <div class="data-readout text-[var(--color-terminal-green)]">0.03%</div>
            <div class="data-readout text-[10px]">ERROR RATE</div>
          </div>
        </div>
      </div>

      <!-- Right: Health indicators -->
      <div class="p-6 md:p-10">
        <div class="micro-type mb-6 text-[var(--color-accent)]">System Health</div>
        <div class="space-y-6">
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="data-readout text-[var(--color-fg-primary)]">CPU</span>
              <span class="data-readout text-[var(--color-terminal-green)]">23.4%</span>
            </div>
            <div class="h-1 bg-[var(--color-border)]">
              <div class="h-full bg-[var(--color-terminal-green)]" style="width: 23.4%"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="data-readout text-[var(--color-fg-primary)]">MEMORY</span>
              <span class="data-readout text-[var(--color-terminal-green)]">67.2%</span>
            </div>
            <div class="h-1 bg-[var(--color-border)]">
              <div class="h-full bg-[var(--color-terminal-green)]" style="width: 67.2%"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="data-readout text-[var(--color-fg-primary)]">GPU</span>
              <span class="data-readout text-[var(--color-terminal-green)]">89.1%</span>
            </div>
            <div class="h-1 bg-[var(--color-border)]">
              <div class="h-full bg-[var(--color-accent)]" style="width: 89.1%"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="data-readout text-[var(--color-fg-primary)]">DISK I/O</span>
              <span class="data-readout text-[var(--color-fg-primary)]">412 MB/s</span>
            </div>
            <div class="h-1 bg-[var(--color-border)]">
              <div class="h-full bg-[var(--color-fg-primary)]" style="width: 56%"></div>
            </div>
          </div>
        </div>
        <div class="mt-6 pt-4 border-t border-[var(--color-border)]">
          <div class="data-readout">
            <span class="text-[var(--color-terminal-green)]">●</span> ALL SYSTEMS NOMINAL
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
