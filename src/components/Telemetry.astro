---
// Telemetry - centered content
---

<section id="telemetry" class="border-b border-[var(--color-border)]">
  <div class="max-w-[1400px] mx-auto">
    <!-- Section header -->
    <div class="border-b border-[var(--color-border)] px-6 md:px-12 py-5">
      <div class="flex items-center justify-center gap-4">
        <span class="text-[var(--color-fg-secondary)]" aria-hidden="true">[</span>
        <h2 class="macro-type text-lg md:text-xl">Telemetry</h2>
        <span class="text-[var(--color-fg-secondary)]" aria-hidden="true">]</span>
        <span class="micro-type text-[10px]">LIVE FEED</span>
      </div>
    </div>

    <!-- Telemetry grid - centered, equal columns -->
    <div class="brutalist-grid grid-cols-1 md:grid-cols-3">
      <!-- Panel 1 -->
      <div class="p-8 md:p-14 text-center">
        <div class="micro-type mb-6 text-[var(--color-accent)]">Neural Processing</div>
        <div class="macro-type text-7xl md:text-8xl mb-4">847</div>
        <div class="data-readout mb-8">Queries processed / 24h</div>
        <div class="sep mb-8"></div>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <div class="data-readout text-[var(--color-fg-primary)] text-base">142ms</div>
            <div class="data-readout text-[10px] mt-1">AVG LATENCY</div>
          </div>
          <div>
            <div class="data-readout text-[var(--color-fg-primary)] text-base">289ms</div>
            <div class="data-readout text-[10px] mt-1">P99 LATENCY</div>
          </div>
          <div>
            <div class="data-readout text-[var(--color-terminal-green)] text-base">0.03%</div>
            <div class="data-readout text-[10px] mt-1">ERROR RATE</div>
          </div>
        </div>
      </div>

      <!-- Panel 2 -->
      <div class="p-8 md:p-14 text-center">
        <div class="micro-type mb-6 text-[var(--color-accent)]">Model Performance</div>
        <div class="macro-type text-7xl md:text-8xl mb-4">97.3<span class="text-3xl">%</span></div>
        <div class="data-readout mb-8">Accuracy index / benchmark</div>
        <div class="sep mb-8"></div>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <div class="data-readout text-[var(--color-fg-primary)] text-base">0.967</div>
            <div class="data-readout text-[10px] mt-1">F1 SCORE</div>
          </div>
          <div>
            <div class="data-readout text-[var(--color-fg-primary)] text-base">0.984</div>
            <div class="data-readout text-[10px] mt-1">AUC-ROC</div>
          </div>
          <div>
            <div class="data-readout text-[var(--color-terminal-green)] text-base">142ms</div>
            <div class="data-readout text-[10px] mt-1">INFERENCE</div>
          </div>
        </div>
      </div>

      <!-- Panel 3 -->
      <div class="p-8 md:p-14 text-center">
        <div class="micro-type mb-6 text-[var(--color-accent)]">System Health</div>
        <div class="macro-type text-7xl md:text-8xl mb-4">99.97<span class="text-3xl">%</span></div>
        <div class="data-readout mb-8">Uptime / availability</div>
        <div class="sep mb-8"></div>
        <div class="space-y-4">
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="data-readout text-[var(--color-fg-primary)]">CPU</span>
              <span class="data-readout text-[var(--color-terminal-green)]">23.4%</span>
            </div>
            <div class="h-1.5 bg-[var(--color-border)]">
              <div class="h-full bg-[var(--color-terminal-green)]" style="width: 23.4%"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="data-readout text-[var(--color-fg-primary)]">MEMORY</span>
              <span class="data-readout text-[var(--color-terminal-green)]">67.2%</span>
            </div>
            <div class="h-1.5 bg-[var(--color-border)]">
              <div class="h-full bg-[var(--color-terminal-green)]" style="width: 67.2%"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="data-readout text-[var(--color-fg-primary)]">GPU</span>
              <span class="data-readout text-[var(--color-terminal-green)]">89.1%</span>
            </div>
            <div class="h-1.5 bg-[var(--color-border)]">
              <div class="h-full bg-[var(--color-accent)]" style="width: 89.1%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom status -->
    <div class="border-t border-[var(--color-border)] px-6 md:px-12 py-4">
      <div class="flex items-center justify-center gap-4">
        <span class="text-[var(--color-terminal-green)]" aria-hidden="true">●</span>
        <span class="data-readout">ALL SYSTEMS NOMINAL</span>
        <span class="text-[var(--color-border)]" aria-hidden="true">|</span>
        <span class="data-readout">LAST UPDATE: {new Date().toLocaleTimeString('en-US', { hour12: false })} UTC</span>
      </div>
    </div>
  </div>
</section>
