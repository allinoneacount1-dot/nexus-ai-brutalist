---
// Telemetry - brutalist grid
---

<section id="telemetry" class="border-b-2 border-[var(--color-border)] bg-[var(--color-bg-primary)]">
  <div class="wrap py-4">
    <div class="flex items-center justify-center gap-4">
      <span class="text-[var(--color-fg-secondary)]" aria-hidden="true">[</span>
      <h2 class="macro-type text-base md:text-lg">TELEMETRY</h2>
      <span class="text-[var(--color-fg-secondary)]" aria-hidden="true">]</span>
      <span class="micro-type text-[10px]">LIVE FEED</span>
    </div>
  </div>
  <div class="border-t-2 border-b-2 border-[var(--color-border)]">
    <div class="brutalist-grid grid-cols-1 md:grid-cols-3">
      <div class="p-6 md:p-10 text-center border-b md:border-b-0 md:border-r border-[var(--color-border)]">
        <div class="micro-type text-[10px] mb-4 text-[var(--color-accent)]">[ NEURAL PROCESSING ]</div>
        <div class="macro-type text-6xl md:text-7xl mb-3">847</div>
        <div class="micro-type text-[10px] mb-6">QUERIES PROCESSED / 24H</div>
        <div class="sep mb-6"></div>
        <div class="grid grid-cols-3 gap-2">
          <div>
            <div class="micro-type text-[10px] text-[var(--color-fg-primary)]">142MS</div>
            <div class="micro-type text-[8px]">AVG LATENCY</div>
          </div>
          <div>
            <div class="micro-type text-[10px] text-[var(--color-fg-primary)]">289MS</div>
            <div class="micro-type text-[8px]">P99 LATENCY</div>
          </div>
          <div>
            <div class="micro-type text-[10px] text-[var(--color-terminal-green)]">0.03%</div>
            <div class="micro-type text-[8px]">ERROR RATE</div>
          </div>
        </div>
      </div>
      <div class="p-6 md:p-10 text-center border-b md:border-b-0 md:border-r border-[var(--color-border)]">
        <div class="micro-type text-[10px] mb-4 text-[var(--color-accent)]">[ MODEL PERFORMANCE ]</div>
        <div class="macro-type text-6xl md:text-7xl mb-3">97.3<span class="text-2xl">%</span></div>
        <div class="micro-type text-[10px] mb-6">ACCURACY INDEX / BENCHMARK</div>
        <div class="sep mb-6"></div>
        <div class="grid grid-cols-3 gap-2">
          <div>
            <div class="micro-type text-[10px] text-[var(--color-fg-primary)]">0.967</div>
            <div class="micro-type text-[8px]">F1 SCORE</div>
          </div>
          <div>
            <div class="micro-type text-[10px] text-[var(--color-fg-primary)]">0.984</div>
            <div class="micro-type text-[8px]">AUC-ROC</div>
          </div>
          <div>
            <div class="micro-type text-[10px] text-[var(--color-terminal-green)]">142MS</div>
            <div class="micro-type text-[8px]">INFERENCE</div>
          </div>
        </div>
      </div>
      <div class="p-6 md:p-10 text-center">
        <div class="micro-type text-[10px] mb-4 text-[var(--color-accent)]">[ SYSTEM HEALTH ]</div>
        <div class="macro-type text-6xl md:text-7xl mb-3">99.97<span class="text-2xl">%</span></div>
        <div class="micro-type text-[10px] mb-6">UPTIME / AVAILABILITY</div>
        <div class="sep mb-6"></div>
        <div class="space-y-3">
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="micro-type text-[10px] text-[var(--color-fg-primary)]">CPU</span>
              <span class="micro-type text-[10px] text-[var(--color-terminal-green)]">23.4%</span>
            </div>
            <div class="h-1 bg-[var(--color-border)]"><div class="h-full bg-[var(--color-terminal-green)]" style="width: 23.4%"></div></div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="micro-type text-[10px] text-[var(--color-fg-primary)]">MEMORY</span>
              <span class="micro-type text-[10px] text-[var(--color-terminal-green)]">67.2%</span>
            </div>
            <div class="h-1 bg-[var(--color-border)]"><div class="h-full bg-[var(--color-terminal-green)]" style="width: 67.2%"></div></div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="micro-type text-[10px] text-[var(--color-fg-primary)]">GPU</span>
              <span class="micro-type text-[10px] text-[var(--color-terminal-green)]">89.1%</span>
            </div>
            <div class="h-1 bg-[var(--color-border)]"><div class="h-full bg-[var(--color-accent)]" style="width: 89.1%"></div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="wrap py-3">
    <div class="flex items-center justify-center gap-4">
      <span class="text-[var(--color-terminal-green)]" aria-hidden="true">+</span>
      <span class="micro-type text-[10px]">ALL SYSTEMS NOMINAL</span>
      <span class="text-[var(--color-border)]" aria-hidden="true">|</span>
      <span class="micro-type text-[10px]">LAST UPDATE: {new Date().toLocaleTimeString('en-US', { hour12: false })} UTC</span>
    </div>
  </div>
</section>
