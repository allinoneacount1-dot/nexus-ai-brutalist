---
// Footer - minimal, no duplicate warning stripe
---

<footer class="border-t border-[var(--color-border)]">
  <div class="max-w-[1400px] mx-auto px-4 md:px-8 py-8 md:py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <div class="macro-type text-xl mb-4">NEXUS AI</div>
        <div class="data-readout">
          TACTICAL INTELLIGENCE<br/>
          EXTRACTION SYSTEM
        </div>
      </div>

      <!-- Links -->
      <div>
        <div class="micro-type mb-4 text-[var(--color-accent)]">Navigation</div>
        <div class="space-y-2">
          <div><a href="#telemetry" class="data-readout hover:text-[var(--color-fg-primary)] transition-colors">/// Telemetry</a></div>
          <div><a href="#capabilities" class="data-readout hover:text-[var(--color-fg-primary)] transition-colors">/// Capabilities</a></div>
          <div><a href="#stats" class="data-readout hover:text-[var(--color-fg-primary)] transition-colors">/// Analytics</a></div>
          <div><a href="#access" class="data-readout hover:text-[var(--color-fg-primary)] transition-colors">/// Request Access</a></div>
        </div>
      </div>

      <!-- Status -->
      <div>
        <div class="micro-type mb-4 text-[var(--color-accent)]">System Status</div>
        <div class="space-y-2">
          <div class="flex items-center gap-2">
            <span class="text-[var(--color-terminal-green)]" aria-hidden="true">●</span>
            <span class="data-readout">Neural Engine: Online</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-[var(--color-terminal-green)]" aria-hidden="true">●</span>
            <span class="data-readout">Data Pipeline: Active</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-[var(--color-terminal-green)]" aria-hidden="true">●</span>
            <span class="data-readout">Inference Node: Ready</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-[var(--color-border)] pt-6">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="data-readout">
          © {new Date().getFullYear()} NEXUS AI SYSTEMS // ALL RIGHTS RESERVED
        </div>
        <div class="data-readout">
          REV 2.6 // BUILD {Math.floor(Date.now() / 1000)} // CLASSIFICATION: PUBLIC
        </div>
      </div>
    </div>
  </div>
</footer>
