---
// Footer - brutalist
---

<footer class="border-t-2 border-[var(--color-border)] bg-[var(--color-bg-primary)]">
  <div class="wrap py-8 md:py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <div class="text-center md:text-left">
        <div class="macro-type text-lg mb-4">NEXUS AI</div>
        <div class="micro-type text-[10px]">TACTICAL INTELLIGENCE<br/>EXTRACTION SYSTEM</div>
      </div>
      <div class="text-center">
        <div class="micro-type text-[10px] mb-4 text-[var(--color-accent)]">[ NAVIGATION ]</div>
        <div class="space-y-2">
          <div><a href="#telemetry" class="micro-type text-[10px] hover:text-[var(--color-fg-primary)] transition-colors">/// TELEMETRY</a></div>
          <div><a href="#capabilities" class="micro-type text-[10px] hover:text-[var(--color-fg-primary)] transition-colors">/// CAPABILITIES</a></div>
          <div><a href="#stats" class="micro-type text-[10px] hover:text-[var(--color-fg-primary)] transition-colors">/// ANALYTICS</a></div>
          <div><a href="#access" class="micro-type text-[10px] hover:text-[var(--color-fg-primary)] transition-colors">/// REQUEST ACCESS</a></div>
        </div>
      </div>
      <div class="text-center md:text-right">
        <div class="micro-type text-[10px] mb-4 text-[var(--color-accent)]">[ SYSTEM STATUS ]</div>
        <div class="space-y-2">
          <div class="flex items-center justify-center md:justify-end gap-2">
            <span class="micro-type text-[10px]">NEURAL ENGINE: ONLINE</span>
            <span class="text-[var(--color-terminal-green)]" aria-hidden="true">+</span>
          </div>
          <div class="flex items-center justify-center md:justify-end gap-2">
            <span class="micro-type text-[10px]">DATA PIPELINE: ACTIVE</span>
            <span class="text-[var(--color-terminal-green)]" aria-hidden="true">+</span>
          </div>
          <div class="flex items-center justify-center md:justify-end gap-2">
            <span class="micro-type text-[10px]">INFERENCE NODE: READY</span>
            <span class="text-[var(--color-terminal-green)]" aria-hidden="true">+</span>
          </div>
        </div>
      </div>
    </div>
    <div class="border-t border-[var(--color-border)] pt-6">
      <div class="flex flex-wrap items-center justify-center gap-4">
        <div class="micro-type text-[10px]">© {new Date().getFullYear()} NEXUS AI SYSTEMS // ALL RIGHTS RESERVED</div>
        <div class="text-[var(--color-border)]" aria-hidden="true">|</div>
        <div class="micro-type text-[10px]">REV 2.6 // CLASSIFICATION: PUBLIC</div>
      </div>
    </div>
  </div>
</footer>
