---
// Header - centered nav
---

<header class="border-b border-[var(--color-border)] sticky top-0 z-50 bg-[var(--color-bg-primary)]">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <div class="flex items-center justify-center h-20 md:h-24 relative">
      <!-- Logo - left -->
      <a href="/" class="flex items-center gap-4 no-absolute left-0">
        <span class="macro-type text-xl md:text-2xl tracking-tighter text-[var(--color-fg-primary)]">NEXUS</span>
        <span class="micro-type text-[10px] hidden md:block">TACTICAL AI SYS</span>
      </a>

      <!-- Nav - center -->
      <nav class="hidden md:flex items-center gap-10 absolute left-1/2 -translate-x-1/2" aria-label="Main navigation">
        <a href="#telemetry" class="micro-type hover:text-[var(--color-accent)] transition-colors">Telemetry</a>
        <a href="#capabilities" class="micro-type hover:text-[var(--color-accent)] transition-colors">Capabilities</a>
        <a href="#stats" class="micro-type hover:text-[var(--color-accent)] transition-colors">Analytics</a>
      </nav>

      <!-- CTA - right -->
      <div class="hidden md:block absolute right-0">
        <a href="#access" class="btn-brutalist-accent btn-brutalist text-[10px] py-2 px-4">Request Access</a>
      </div>

      <!-- Mobile menu trigger -->
      <button
        id="mobile-menu-open"
        class="md:hidden micro-type text-[var(--color-fg-secondary)] hover:text-[var(--color-accent)] transition-colors bg-transparent border-none cursor-pointer absolute right-0"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        [ MENU ]
      </button>
    </div>
  </div>
  <div class="accent-line"></div>
</header>
